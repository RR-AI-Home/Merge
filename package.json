{
  "name": "merge-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js",
    "create:game": "node scripts/create-game.mjs",
    "validate:themes": "node scripts/validate-all-themes.mjs",
    "smoke:apps": "node scripts/smoke-app.mjs",
    "verify:playable": "node scripts/verify-playable-apps.mjs",
    "verify": "npm test && npm run validate:themes && npm run smoke:apps && npm run verify:playable"
  },
  "engines": {
    "node": ">=20"
  }
}
